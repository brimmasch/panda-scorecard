{
	"name": "panda-scorecard",
	"image": "mcr.microsoft.com/devcontainers/javascript-node:4-22-trixie",
	"mounts": [
		"source=panda-scorecard-node_modules,target=${containerWorkspaceFolder}/node_modules,type=volume"
	],
	"postCreateCommand": "sudo chown -R node:node /workspaces/panda-scorecard/node_modules && npm install",
	"forwardPorts": [5173],
	"customizations": {
		"vscode": {
			"extensions": [
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode"
			]
		}
	}
}
